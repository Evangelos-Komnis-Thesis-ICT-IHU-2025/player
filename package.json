{
  "name": "scorm-player",
  "version": "0.1.0",
  "private": true,
  "description": "Node/TypeScript SCORM player service",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && npm run test:unit",
    "test:unit": "tsx --test src/**/*.test.ts",
